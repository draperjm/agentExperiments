# Dockerfile.frontend
FROM nginx:alpine

# Copy the HTML files to the Nginx default directory
COPY index.html /usr/share/nginx/html/index.html
COPY validation_report.html /usr/share/nginx/html/validation_report.html

# Reverse-proxy config (routes /api/decomposer/ and /api/orchestrator/ to backend)
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expose port 80
EXPOSE 80